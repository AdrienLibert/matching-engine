{
    "type": "object",
    "version": "1.0.0",
    "metadata": {
        "name": "order",
        "topic": "orders.topic"
    },
    "properties": {
        "order_id": {
            "type": "string"
        },
        "order_type": {
            "type": "string"
        },
        "price": {
            "type": "number"
        },
        "quantity": {
            "type": "integer",
            "minimum": 1,
            "description": "Quantity is normalized to a strictly positive value. Side is expressed through action."
        },
        "action": {
            "type": "string",
            "enum": ["BUY", "SELL"],
            "description": "Explicit order side metadata used with unsigned quantity."
        },
        "timestamp": {
            "type": "integer"
        }
    },
    "required": ["order_id", "order_type", "price", "quantity", "action", "timestamp"]
}